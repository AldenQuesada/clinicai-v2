{
  "name": "clinicai-v2",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.5.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:lara": "turbo run dev --filter=@clinicai/lara",
    "dev:mira": "turbo run dev --filter=@clinicai/mira",
    "dev:dashboard": "turbo run dev --filter=@clinicai/dashboard",
    "dev:flipbook": "turbo run dev --filter=@clinicai/flipbook",
    "build": "turbo run build --filter=@clinicai/lara",
    "build:lara": "turbo run build --filter=@clinicai/lara",
    "build:mira": "turbo run build --filter=@clinicai/mira",
    "build:dashboard": "turbo run build --filter=@clinicai/dashboard",
    "build:flipbook": "turbo run build --filter=@clinicai/flipbook",
    "build:all": "turbo run build",
    "start": "pnpm --filter=@clinicai/lara start",
    "start:lara": "pnpm --filter=@clinicai/lara start",
    "start:mira": "pnpm --filter=@clinicai/mira start",
    "start:dashboard": "pnpm --filter=@clinicai/dashboard start",
    "start:flipbook": "pnpm --filter=@clinicai/flipbook start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck --filter=!@clinicai/flipbook",
    "typecheck:all": "turbo run typecheck",
    "typecheck:flipbook": "turbo run typecheck --filter=@clinicai/flipbook",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:types": "node scripts/generate-types.mjs",
    "db:apply": "node scripts/apply-migration.mjs",
    "db:divergence": "node scripts/divergence-check.mjs",
    "e2e:setup": "node scripts/e2e-setup.mjs",
    "e2e:cleanup": "node scripts/e2e-cleanup.mjs"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "turbo": "^2.3.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
