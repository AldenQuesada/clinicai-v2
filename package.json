{
  "name": "clinicai-v2",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.5.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:lara": "turbo run dev --filter=@clinicai/lara",
    "dev:dashboard": "turbo run dev --filter=@clinicai/dashboard",
    "build": "turbo run build --filter=@clinicai/lara",
    "build:lara": "turbo run build --filter=@clinicai/lara",
    "build:dashboard": "turbo run build --filter=@clinicai/dashboard",
    "build:all": "turbo run build",
    "start": "pnpm --filter=@clinicai/lara start",
    "start:lara": "pnpm --filter=@clinicai/lara start",
    "start:dashboard": "pnpm --filter=@clinicai/dashboard start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5"
  }
}
