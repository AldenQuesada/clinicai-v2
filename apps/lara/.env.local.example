# ─── Supabase (mesmo projeto da clinic-dashboard) ──────────────
NEXT_PUBLIC_SUPABASE_URL=https://oqboitkpcvuaudouwvkl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx-anon-key-publica-respeitando-RLS
SUPABASE_SERVICE_ROLE_KEY=xxx-service-role-NUNCA-no-client

# ─── LLM ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Transcrição áudio ─────────────────────────────────────────
GROQ_API_KEY=gsk_xxx

# ─── WhatsApp Cloud API (Meta) ──────────────────────────────────
# DEPRECATED em multi-tenant · credenciais agora vêm de wa_numbers (ADR-028).
# Mantido apenas como fallback de dev local · em prod, NÃO setar.
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=

# ─── Webhook security (audit fix N1, 2026-04-27) ───────────────
# Meta App Secret pra validar X-Hub-Signature-256 do webhook.
# OBRIGATÓRIO em produção (NODE_ENV=production) · validateMetaSignature
# faz fail-CLOSED se ausente. Pegar em: Meta Developer Dashboard > App Settings > Basic.
META_APP_SECRET=

# ─── Cron security (audit fix N3, 2026-04-27) ──────────────────
# Secret pra autenticar /api/cron/reactivate · gerar com `openssl rand -hex 32`.
# Cron caller envia header: x-cron-secret: <valor>
LARA_CRON_SECRET=

# ─── Tenant resolve mode (audit fix N23, 2026-04-27) ───────────
# 'true' faz tenant-resolve.ts lançar erro quando phone_number_id não casa
# com nenhum wa_number. Default (false) cai em FALLBACK_CLINIC_ID Mirian.
# LIGAR EM PROD assim que todos wa_numbers estiverem populados.
LARA_TENANT_FAILFAST=false

# ─── App config ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3005
NEXT_PUBLIC_PAINEL_URL=https://painel.miriandpaula.com.br

# ─── Storage buckets pra fotos antes/depois ────────────────────
# Path no Supabase Storage (default before-after/<funil>)
BUCKET_FUNIL_OLHEIRAS=before-after/olheiras
BUCKET_FUNIL_FULLFACE=before-after/fullface

# ─── Logging ────────────────────────────────────────────────────
LOG_LEVEL=info
