# =============================================================================
# Mira (apps/mira) · variaveis de ambiente
# =============================================================================
# Copie pra .env.local em dev · NUNCA commite .env.local com valores reais.
# Em prod, configurar via Easypanel UI · cada deploy le o ENV do container.

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://oqboitkpcvuaudouwvkl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Evolution API (WhatsApp gateway)
# -----------------------------------------------------------------------------
EVOLUTION_API_URL=https://evolution.aldenquesada.site
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_MIRA=mira-mirian
EVOLUTION_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# AI providers (classify + transcribe)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# Cron auth (Easypanel/GitHub Actions chamam crons com header)
# -----------------------------------------------------------------------------
MIRA_CRON_SECRET=

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
# WEBHOOK_ASYNC_ENABLED=true · default true (fast ack 202 + worker drena).
# Set 'false' apenas pra rollback rapido pro path sync legado.
WEBHOOK_ASYNC_ENABLED=true

# Log level Pino · default 'info'. 'debug' so em dev/troubleshoot.
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# F6 · Alert system (Sentry + Slack)
# -----------------------------------------------------------------------------
# Vazio = noop · SDK fica inerte, nao manda eventos, nao crash. Popular em prod
# (Easypanel) pra ativar captura.

# Sentry DSN · captura errors via createLoggerWithAlerts (.error()) ou
# alertSentry/alertCritical diretos. Sem DSN, withSentryConfig nao envolve
# next.config.ts e sourcemap upload nao tenta autenticar.
# Pegar em https://sentry.io/settings/<org>/projects/<project>/keys/
NEXT_PUBLIC_SENTRY_DSN=

# Sentry build-time (opcional · so usado pra upload de sourcemaps em CI):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Slack incoming webhook URL · alertSlack/alertCritical postam aqui.
# Severities: info (verde), warn (ambar), error (vermelho). Sem webhook, fica
# noop silencioso. Criar em https://api.slack.com/apps > Incoming Webhooks.
SLACK_WEBHOOK_URL=

# Rate limit de alertas warn/error por minuto, por evento (msg unique).
# Default 5 · evita burst de erros repetidos saturarem Slack/Sentry. Aumentar
# se tiver muito ruido de alertas similares; reduzir pra ser mais conservador.
ALERT_THRESHOLD_WARN_RATE_PER_MIN=5
