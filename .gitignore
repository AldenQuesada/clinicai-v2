packages/*/src/**/*.d.ts.map
packages/*/src/**/*.js
!packages/*/src/**/*.test.ts

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# IDE
.vscode/
.idea/
.DS_Store

